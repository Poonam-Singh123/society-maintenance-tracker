# Backend
PORT=5000
JWT_SECRET=change-this-to-a-long-random-string
FRONTEND_URL=http://localhost:5173

# Default admin (created by npm run seed)
ADMIN_NAME=Society Admin
ADMIN_EMAIL=admin@society.com
ADMIN_PASSWORD=admin123

# Email (optional — uses console log when not configured)
# Free tier options: Gmail App Password, Brevo, Mailtrap, Ethereal
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM="Society Tracker <noreply@society.com>"

# Frontend (optional — defaults to Vite proxy)
# VITE_API_URL=http://localhost:5000
